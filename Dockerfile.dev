# Development Dockerfile for the NestJS backend
# Source code is mounted via volume in docker-compose, so this file only:
# 1. Sets up the base image
# 2. Installs dependencies
# 3. Generates the Prisma client
# 4. Runs the dev server (with hot reload)

FROM node:20-alpine

WORKDIR /app

# Copy only package files first — Docker caches this layer
# unless package.json or package-lock.json change.
# This means npm install only re-runs when deps actually change.
COPY package*.json ./

RUN npm install

# Copy Prisma schema and generate the client
COPY prisma ./prisma
RUN npx prisma generate

# The actual source code will be mounted as a volume at runtime.
# We don't COPY it here — that would shadow the volume mount.

EXPOSE 3000

CMD ["npm", "run", "start:dev"]
